# Env file untuk nyxchamp-stack docker compose.
# Copy ke .env (di /opt/nyxchamp-stack/) lalu edit. JANGAN commit .env.

# MySQL root password (untuk admin/dump). HARUS di-set sebelum up.
MYSQL_ROOT_PASSWORD=AsusTerbaik2-nyxchamp-root

# Database + user untuk aplikasi Laravel.
MYSQL_DATABASE=nyxchamp
MYSQL_USER=nyxchamp
MYSQL_PASSWORD=AsusTerbaik2-nyxchamp-app
